#!/usr/bin/env bash

set -euo pipefail

ENGINES_DIR="${UNREAL_ENGINES_DIR:-$HOME/Unreal-Engines}"
LOG_MODE=false
PROJECT_FILE=""
launch_args=()

read_project_engine() {
  local project_file="$1"
  local association

  association="$(jq -r '.EngineAssociation // empty' "$project_file")"
  [[ -n "$association" ]] || return 1

  printf '%s\n' "$association"
}

resolve_path() {
  local path="$1"

  if command -v realpath >/dev/null 2>&1; then
    realpath "$path"
    return 0
  fi

  if command -v readlink >/dev/null 2>&1; then
    readlink -f "$path"
    return 0
  fi

  printf '%s\n' "$path"
}

find_engine_by_association() {
  local association="$1"
  local engine_dir version_file major minor patch folder_name sort_key

  while IFS= read -r -d '' engine_dir; do
    version_file="$engine_dir/Engine/Build/Build.version"
    [[ -f "$version_file" ]] || continue

    major="$(jq -r '.MajorVersion // empty' "$version_file")"
    minor="$(jq -r '.MinorVersion // empty' "$version_file")"
    patch="$(jq -r '.PatchVersion // empty' "$version_file")"
    [[ -n "$major" && -n "$minor" && -n "$patch" ]] || continue

    folder_name="$(basename "$engine_dir")"
    if [[ "$folder_name" == *"$association"* || "$association" == "$major.$minor.$patch" ]]; then
      printf '%s\n' "$engine_dir"
      return 0
    fi
  done < <(find "$ENGINES_DIR" -mindepth 1 -maxdepth 1 -type d -print0)

  return 1
}

build_selected_entry() {
  local version="$1"
  local folder_name="$2"
  local editor_bin="$3"
  printf '%s\t%s\t%s\n' "$version" "$folder_name" "$editor_bin"
}

for arg in "$@"; do
  if [[ "$arg" == "--log" ]]; then
    LOG_MODE=true
  elif [[ "$arg" == *.uproject ]]; then
    if [[ -n "$PROJECT_FILE" ]]; then
      printf 'ue-launch: only one .uproject path can be provided\n' >&2
      exit 1
    fi

    PROJECT_FILE="$arg"
  else
    launch_args+=("$arg")
  fi
done

if [[ -n "$PROJECT_FILE" && ! -f "$PROJECT_FILE" ]]; then
  printf 'ue-launch: project file not found: %s\n' "$PROJECT_FILE" >&2
  exit 1
fi

if [[ -n "$PROJECT_FILE" ]]; then
  PROJECT_FILE="$(resolve_path "$PROJECT_FILE")"
fi

project_engine=""
if [[ -n "$PROJECT_FILE" ]]; then
  if ! project_engine="$(read_project_engine "$PROJECT_FILE")"; then
    printf 'ue-launch: project file has no EngineAssociation: %s\n' "$PROJECT_FILE" >&2
    exit 1
  fi
fi

if [[ ! -d "$ENGINES_DIR" ]]; then
  printf 'ue-launch: engines directory not found: %s\n' "$ENGINES_DIR" >&2
  exit 1
fi

if ! command -v jq >/dev/null 2>&1; then
  printf 'ue-launch: jq is required to read Build.version files\n' >&2
  exit 1
fi

entries=()

while IFS= read -r -d '' engine_dir; do
  version_file="$engine_dir/Engine/Build/Build.version"
  editor_bin="$engine_dir/Engine/Binaries/Linux/UnrealEditor"

  [[ -f "$version_file" ]] || continue
  [[ -x "$editor_bin" ]] || continue

  major="$(jq -r '.MajorVersion // empty' "$version_file")"
  minor="$(jq -r '.MinorVersion // empty' "$version_file")"
  patch="$(jq -r '.PatchVersion // empty' "$version_file")"

  [[ -n "$major" && -n "$minor" && -n "$patch" ]] || continue

  version="$major.$minor.$patch"
  folder_name="$(basename "$engine_dir")"
  sort_key="$(printf '%03d.%03d.%03d' "$major" "$minor" "$patch")"
  entries+=("$sort_key|$version|$folder_name|$editor_bin")
done < <(find "$ENGINES_DIR" -mindepth 1 -maxdepth 1 -type d -print0)

if [[ ${#entries[@]} -eq 0 ]]; then
  printf 'ue-launch: no Unreal Editor installs found in %s\n' "$ENGINES_DIR" >&2
  exit 1
fi

if [[ -n "$project_engine" ]]; then
  if matched_engine="$(find_engine_by_association "$project_engine")"; then
    editor_bin="$matched_engine/Engine/Binaries/Linux/UnrealEditor"
    selected="$(build_selected_entry "$project_engine" "$(basename "$matched_engine")" "$editor_bin")"
  fi
fi

IFS=$'\n' sorted_entries=($(printf '%s\n' "${entries[@]}" | sort -r))
unset IFS

selected="${selected:-}"

if [[ -z "$selected" ]] && command -v fzf >/dev/null 2>&1; then
  selected="$({
    for entry in "${sorted_entries[@]}"; do
      IFS='|' read -r _ version folder_name editor_bin <<<"$entry"
      build_selected_entry "$version" "$folder_name" "$editor_bin"
    done
  } | fzf --prompt='Unreal Engine > ' --with-nth=1,2 --delimiter=$'\t' --exit-0)"

  [[ -n "$selected" ]] || exit 0
elif [[ -z "$selected" ]]; then
  printf 'ue-launch: fzf is required to choose an Unreal Engine version\n' >&2
  exit 1
fi

editor_bin="${selected##*$'\t'}"

editor_args=()

if [[ -n "$PROJECT_FILE" ]]; then
  editor_args+=("$PROJECT_FILE")
fi

editor_args+=("${launch_args[@]}")

if [[ "$LOG_MODE" == true ]]; then
  exec env SDL_VIDEODRIVER=x11 "$editor_bin" "${editor_args[@]}"
fi

nohup env SDL_VIDEODRIVER=x11 "$editor_bin" "${editor_args[@]}" >/dev/null 2>&1 &
printf 'ue-launch: started %s in background\n' "$(basename "$(dirname "$(dirname "$editor_bin")")")"
